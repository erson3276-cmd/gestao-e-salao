  "dynamicRoutes": [
    {
      "page": "/b/[slug]",
      "regex": "^/b/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/b/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/book/[salonId]",
      "regex": "^/book/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPsalonId": "nxtPsalonId"
      },
